apiVersion: data.infoblox.com/v1alpha1
kind: DataPackage
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  version: 0.1.0
  labels:
    team: {{ .Team }}
spec:
  type: dataset
  description: {{ .Description }}
  owner: {{ .Owner }}
  
  outputs:
    - name: dataset
      type: s3-prefix
      binding: output.datasets
      schema:
        type: parquet
      classification:
        pii: false
        sensitivity: internal
        dataCategory: curated-data
