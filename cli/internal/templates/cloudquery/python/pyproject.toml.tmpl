[build-system]
requires = ["setuptools>=69.0"]
build-backend = "setuptools.build_meta"

[project]
name = "{{.Name}}"
version = "0.1.0"
description = "{{.Description}}"
requires-python = ">=3.12"
dependencies = [
    "cloudquery-plugin-sdk>=0.1.52",
    "pyarrow>=23.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
]

[tool.pytest.ini_options]
pythonpath = ["."]
