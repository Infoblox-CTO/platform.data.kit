"""
Tests for the example_resource table and resolver.
"""
from plugin.tables.example_resource import ExampleResourceTable, ExampleResourceResolver


class TestExampleResourceTable:
    """Tests for the ExampleResourceTable."""

    def test_table_name(self):
        table = ExampleResourceTable()
        assert table.name == "example_resource"

    def test_table_has_columns(self):
        table = ExampleResourceTable()
        assert len(table.columns) == 4

    def test_column_names(self):
        table = ExampleResourceTable()
        col_names = [c.name for c in table.columns]
        assert "id" in col_names
        assert "name" in col_names
        assert "value" in col_names
        assert "active" in col_names

    def test_primary_key(self):
        table = ExampleResourceTable()
        pk_cols = [c for c in table.columns if c.primary_key]
        assert len(pk_cols) == 1
        assert pk_cols[0].name == "id"


class TestExampleResourceResolver:
    """Tests for the ExampleResourceResolver."""

    def test_resolve_returns_rows(self):
        table = ExampleResourceTable()
        resolver = ExampleResourceResolver(table=table)
        rows = list(resolver.resolve(client=None, parent_resource=None))
        assert len(rows) == 2

    def test_resolve_row_has_required_keys(self):
        table = ExampleResourceTable()
        resolver = ExampleResourceResolver(table=table)
        rows = list(resolver.resolve(client=None, parent_resource=None))
        for row in rows:
            assert "id" in row
            assert "name" in row
            assert "value" in row
            assert "active" in row

    def test_resolve_first_row_values(self):
        table = ExampleResourceTable()
        resolver = ExampleResourceResolver(table=table)
        rows = list(resolver.resolve(client=None, parent_resource=None))
        assert rows[0]["id"] == "example-1"
        assert rows[0]["name"] == "Example Item 1"
        assert rows[0]["value"] == 100
        assert rows[0]["active"] is True
