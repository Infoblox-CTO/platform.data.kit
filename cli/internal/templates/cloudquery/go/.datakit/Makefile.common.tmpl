.DEFAULT_GOAL := help

# -- Meta targets ------------------------------------------------------------

.PHONY: help
help: ## Show this help message
	@printf '\nUsage: make <target>\n\n'
	@printf 'Targets:\n'
	@grep -h -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}' | sort

# -- Development targets -----------------------------------------------------

.PHONY: test
test: ## Run unit tests
	go test ./... -v

.PHONY: lint
lint: ## Run dp lint on the package
	dp lint .

.PHONY: build
build: ## Build the plugin container image
	dp build .

.PHONY: run
run: ## Build and deploy to k3d, discover tables
	dp run .

.PHONY: sync
sync: ## Run a full sync to local files
	dp run . --sync

.PHONY: sync-pg
sync-pg: ## Run a full sync to PostgreSQL
	dp run . --sync --destination postgresql

# -- Code quality targets ----------------------------------------------------

.PHONY: fmt
fmt: ## Format Go source code
	go fmt ./...

.PHONY: vet
vet: ## Run go vet
	go vet ./...

.PHONY: tidy
tidy: ## Run go mod tidy
	go mod tidy

# -- Cleanup targets ---------------------------------------------------------

.PHONY: clean
clean: ## Remove build artifacts and sync output
	rm -rf bin/ dist/ cq-sync-output/ coverage.out coverage.html
