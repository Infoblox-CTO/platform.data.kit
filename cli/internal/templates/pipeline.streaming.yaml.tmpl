apiVersion: data.infoblox.com/v1alpha1
kind: Pipeline
spec:
  image: "${REGISTRY}/{{ .Name }}:${VERSION}"
  mode: streaming
  
  env:
    - name: LOG_LEVEL
      value: info
      
  # Streaming-specific settings
  replicas: 1
  terminationGracePeriodSeconds: 30
  
  livenessProbe:
    httpGet:
      path: /healthz
      port: 8080
    initialDelaySeconds: 10
    periodSeconds: 30
    timeoutSeconds: 5
    failureThreshold: 3
    
  readinessProbe:
    httpGet:
      path: /ready
      port: 8080
    initialDelaySeconds: 5
    periodSeconds: 10
    timeoutSeconds: 3
    successThreshold: 1
    failureThreshold: 3
  
  lineage:
    enabled: true
    heartbeatInterval: 5m
