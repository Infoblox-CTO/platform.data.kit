apiVersion: datakit.infoblox.dev/v1alpha1
kind: Transform
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  version: 0.1.0
  labels:
    team: {{ .Team }}
spec:
  runtime: dbt
  mode: batch
  description: "{{ .Description }}"
  owner: {{ .Owner }}
  image: "${REGISTRY}/{{ .Name }}:${VERSION}"

  config:
    target: production
    project_dir: ./dbt
    profiles_dir: ./dbt
    select: "tag:daily"

  inputs:
    - dataset: {{ .Name }}-input

  outputs:
    - dataset: {{ .Name }}-output

  schedule:
    cron: "30 6 * * *"

  resources:
    cpu: "1"
    memory: "2Gi"
