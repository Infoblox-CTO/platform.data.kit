apiVersion: datakit.infoblox.dev/v1alpha1
kind: Transform
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  version: 0.1.0
  labels:
    team: {{ .Team }}
spec:
  runtime: generic-python
  mode: {{ .Mode }}
  description: "{{ .Description }}"
  owner: {{ .Owner }}
  image: "${REGISTRY}/{{ .Name }}:${VERSION}"

  inputs:
    - asset: {{ .Name }}-input

  outputs:
    - asset: {{ .Name }}-output

  resources:
    cpu: "1"
    memory: "2Gi"
