apiVersion: datakit.infoblox.dev/v1alpha1
kind: DataSet
metadata:
  name: {{ .Name }}-dest-table
  namespace: {{ .Namespace }}
spec:
  store: dest-bucket
  prefix: "{{ .Name }}/"
  format: parquet
  classification: internal
  schema:
    - name: id
      type: integer
    - name: name
      type: string
    - name: created_at
      type: timestamp
