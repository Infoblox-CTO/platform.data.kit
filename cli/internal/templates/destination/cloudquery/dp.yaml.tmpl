apiVersion: data.infoblox.com/v1alpha1
kind: Destination
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  version: 0.1.0
  labels:
    team: {{ .Team }}
spec:
  runtime: cloudquery
  description: "{{ .Description }}"
  owner: {{ .Owner }}

  accepts:
    name: {{ .Name }}-input
    type: s3-prefix
    schema:
      type: parquet

  configSchema:
    properties:
      bucket:
        type: string
        description: "S3 bucket name"
      prefix:
        type: string
        description: "Key prefix"
      compression:
        type: string
        description: "Compression codec"
        enum: ["snappy", "gzip", "zstd"]
        default: "snappy"
    required:
      - bucket
