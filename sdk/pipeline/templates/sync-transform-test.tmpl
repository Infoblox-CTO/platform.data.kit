apiVersion: data.infoblox.com/v1alpha1
kind: PipelineWorkflow
metadata:
  name: {{.Name}}
  description: "Full ETL workflow: sync, transform, test, and publish"
steps:
  - name: sync-data
    type: sync
    input: "TODO-input-asset"
    output: "TODO-output-asset"
    description: "Sync data from input to output"

  - name: transform-data
    type: transform
    asset: "TODO-transform-asset"
    description: "Transform synced data"

  - name: test-output
    type: test
    asset: "TODO-transform-asset"
    command: ["dbt", "test"]
    description: "Validate transformed data"

  - name: publish-results
    type: publish
    notify:
      channels: []
    promote: false
    description: "Publish and notify on completion"
