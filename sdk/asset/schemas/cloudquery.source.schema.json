{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdpp.io/extensions/cloudquery/source/schema.json",
  "title": "CloudQuery Source Extension Configuration",
  "description": "Configuration schema for CloudQuery source plugins",
  "type": "object",
  "required": ["accounts", "regions", "tables"],
  "properties": {
    "accounts": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{12}$"
      },
      "minItems": 1,
      "description": "List of AWS account IDs to sync"
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2}(-[a-z]+-[0-9])?$"
      },
      "minItems": 1,
      "description": "AWS regions to sync"
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "minItems": 1,
      "description": "CloudQuery table names to sync"
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100000,
      "default": 10000,
      "description": "Maximum number of concurrent table resolvers"
    },
    "scheduler": {
      "type": "string",
      "enum": ["dfs", "round-robin"],
      "default": "dfs",
      "description": "Table resolver scheduling strategy"
    }
  },
  "additionalProperties": false
}
