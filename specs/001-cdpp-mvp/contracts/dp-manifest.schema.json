{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdpp.io/schemas/v1alpha1/dp-manifest.schema.json",
  "title": "DataPackage Manifest",
  "description": "Schema for dp.yaml - the root manifest declaring package identity, type, and contracts",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "data.infoblox.com/v1alpha1",
      "description": "Schema version"
    },
    "kind": {
      "type": "string",
      "const": "DataPackage",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,62}$",
          "description": "Package name (DNS-safe, lowercase)"
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,62}$",
          "description": "Team/org namespace"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Key-value labels for filtering"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Arbitrary annotations"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["type", "description", "owner"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["pipeline", "infra", "report"],
          "description": "Package type"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Human-readable purpose"
        },
        "owner": {
          "type": "string",
          "description": "Team or individual owner"
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" },
          "description": "Declared input dependencies"
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactContract" },
          "description": "Declared output artifacts"
        },
        "schedule": {
          "$ref": "#/$defs/scheduleSpec",
          "description": "Scheduling configuration"
        },
        "resources": {
          "$ref": "#/$defs/resourceSpec",
          "description": "CPU/memory requirements"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "pipeline" } }
          },
          "then": {
            "required": ["outputs"],
            "properties": {
              "outputs": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "artifactRef": {
      "type": "object",
      "required": ["name", "type", "binding"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,62}$",
          "description": "Artifact identifier within package"
        },
        "type": {
          "type": "string",
          "enum": ["s3-prefix", "kafka-topic", "postgres-table", "spark-job"],
          "description": "Resource type"
        },
        "binding": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]{0,126}$",
          "description": "Abstract binding reference"
        }
      }
    },
    "artifactContract": {
      "type": "object",
      "required": ["name", "type", "binding", "classification"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,62}$",
          "description": "Artifact identifier within package"
        },
        "type": {
          "type": "string",
          "enum": ["s3-prefix", "kafka-topic", "postgres-table", "spark-job"],
          "description": "Resource type"
        },
        "binding": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]{0,126}$",
          "description": "Abstract binding reference"
        },
        "schema": {
          "$ref": "#/$defs/schemaSpec",
          "description": "Data schema specification"
        },
        "classification": {
          "$ref": "#/$defs/classificationSpec",
          "description": "Data classification metadata"
        }
      }
    },
    "schemaSpec": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["parquet", "avro", "json", "csv"],
          "description": "Data format type"
        },
        "schemaRef": {
          "type": "string",
          "description": "Path to schema file"
        },
        "inline": {
          "type": "object",
          "description": "Inline schema definition"
        }
      }
    },
    "classificationSpec": {
      "type": "object",
      "required": ["sensitivity"],
      "properties": {
        "pii": {
          "type": "boolean",
          "default": false,
          "description": "Contains personally identifiable information"
        },
        "sensitivity": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"],
          "description": "Data sensitivity level"
        },
        "dataCategory": {
          "type": "string",
          "description": "Business domain category"
        },
        "retentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3650,
          "description": "Data retention period in days"
        }
      }
    },
    "scheduleSpec": {
      "type": "object",
      "properties": {
        "cron": {
          "type": "string",
          "pattern": "^(@(annually|yearly|monthly|weekly|daily|hourly)|((\\*|([0-9]|1[0-9]|2[0-9]|3[0-9]|4[0-9]|5[0-9])|\\*\\/([0-9]|1[0-9]|2[0-9]|3[0-9]|4[0-9]|5[0-9])) (\\*|([0-9]|1[0-9]|2[0-3])|\\*\\/([0-9]|1[0-9]|2[0-3])) (\\*|([1-9]|1[0-9]|2[0-9]|3[0-1])|\\*\\/([1-9]|1[0-9]|2[0-9]|3[0-1])) (\\*|([1-9]|1[0-2])|\\*\\/([1-9]|1[0-2])) (\\*|([0-6])|\\*\\/([0-6]))))$",
          "description": "Cron expression for scheduling"
        },
        "timezone": {
          "type": "string",
          "default": "UTC",
          "description": "Timezone for schedule"
        },
        "suspend": {
          "type": "boolean",
          "default": false,
          "description": "Suspend scheduling"
        }
      }
    },
    "resourceSpec": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?(m)?$",
          "description": "CPU request/limit"
        },
        "memory": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti)?$",
          "description": "Memory request/limit"
        }
      }
    }
  }
}
