{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.infoblox.com/schemas/v1alpha1/asset-group.schema.json",
  "title": "AssetGroup Manifest",
  "description": "Schema for an AssetGroup — bundles multiple Assets from a single materialisation",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "data.infoblox.com/v1alpha1",
      "description": "Schema version"
    },
    "kind": {
      "type": "string",
      "const": "AssetGroup",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,62}$",
          "description": "AssetGroup name (DNS-safe, lowercase)"
        },
        "namespace": {
          "type": "string",
          "description": "Team namespace"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Key-value labels for filtering"
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["store", "assets"],
      "properties": {
        "store": {
          "type": "string",
          "description": "Common Store for all assets in the group"
        },
        "assets": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true,
          "description": "List of Asset names in this group"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
