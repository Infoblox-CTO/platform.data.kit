{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdpp.io/schemas/v1alpha1/pipeline-workflow.schema.json",
  "title": "PipelineWorkflow",
  "description": "Multi-step pipeline workflow definition for the Data Platform.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "steps"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "datakit.infoblox.dev/v1alpha1",
      "description": "API version for the pipeline workflow manifest."
    },
    "kind": {
      "type": "string",
      "const": "PipelineWorkflow",
      "description": "Resource kind."
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered sequence of pipeline steps. Steps execute sequentially top-to-bottom.",
      "items": {
        "$ref": "#/$defs/Step"
      }
    }
  },
  "$defs": {
    "Metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,61}[a-z0-9]$",
          "minLength": 3,
          "maxLength": 63,
          "description": "Pipeline name. Must be DNS-safe: lowercase letters, digits, and hyphens."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the pipeline."
        }
      }
    },
    "Step": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,61}[a-z0-9]$",
          "minLength": 3,
          "maxLength": 63,
          "description": "Unique step identifier. Must be DNS-safe."
        },
        "type": {
          "type": "string",
          "enum": ["sync", "transform", "test", "publish", "custom"],
          "description": "Step type discriminator."
        },
        "description": {
          "type": "string",
          "description": "Human-readable step description."
        },
        "source": {
          "type": "string",
          "description": "Source asset name (sync step only)."
        },
        "sink": {
          "type": "string",
          "description": "Sink asset name (sync step only)."
        },
        "asset": {
          "type": "string",
          "description": "Asset name (transform and test steps)."
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Command to execute (test and custom steps)."
        },
        "image": {
          "type": "string",
          "description": "Container image (custom step only)."
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Container arguments (custom step only)."
        },
        "env": {
          "type": "array",
          "items": { "$ref": "#/$defs/EnvVar" },
          "description": "Additional environment variables for this step."
        },
        "notify": {
          "$ref": "#/$defs/NotifyConfig",
          "description": "Notification configuration (publish step only)."
        },
        "promote": {
          "type": "boolean",
          "default": false,
          "description": "Whether to trigger environment promotion (publish step only)."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "sync" } },
            "required": ["type"]
          },
          "then": {
            "required": ["source", "sink"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "transform" } },
            "required": ["type"]
          },
          "then": {
            "required": ["asset"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "test" } },
            "required": ["type"]
          },
          "then": {
            "required": ["asset", "command"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "custom" } },
            "required": ["type"]
          },
          "then": {
            "required": ["image"]
          }
        }
      ]
    },
    "EnvVar": {
      "type": "object",
      "required": ["name", "value"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Environment variable name."
        },
        "value": {
          "type": "string",
          "description": "Environment variable value."
        }
      }
    },
    "NotifyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "channels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Notification channels (e.g., Slack channels)."
        },
        "recipients": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Notification recipients (e.g., email addresses)."
        }
      }
    }
  }
}
