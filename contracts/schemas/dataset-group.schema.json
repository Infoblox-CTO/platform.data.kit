{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datakit.infoblox.dev/schemas/v1alpha1/dataset-group.schema.json",
  "title": "DataSetGroup Manifest",
  "description": "Schema for a DataSetGroup — bundles multiple DataSets from a single materialisation",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "datakit.infoblox.dev/v1alpha1",
      "description": "Schema version"
    },
    "kind": {
      "type": "string",
      "const": "DataSetGroup",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,62}$",
          "description": "DataSetGroup name (DNS-safe, lowercase)"
        },
        "namespace": {
          "type": "string",
          "description": "Team namespace"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Key-value labels for filtering"
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["store", "datasets"],
      "properties": {
        "store": {
          "type": "string",
          "description": "Common Store for all datasets in the group"
        },
        "datasets": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true,
          "description": "List of DataSet names in this group"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
