{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datakit.infoblox.dev/schemas/v1alpha1/transform.schema.json",
  "title": "Transform Manifest",
  "description": "Schema for a Transform — a unit of computation that reads input DataSets and produces output DataSets",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "datakit.infoblox.dev/v1alpha1",
      "description": "Schema version"
    },
    "kind": {
      "type": "string",
      "const": "Transform",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,62}$",
          "description": "Transform name (DNS-safe, lowercase)"
        },
        "namespace": {
          "type": "string",
          "description": "Team namespace"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
          "description": "Semantic version (e.g., 0.1.0)"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Key-value labels for filtering"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Arbitrary annotations"
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["runtime", "inputs", "outputs"],
      "properties": {
        "runtime": {
          "type": "string",
          "enum": ["cloudquery", "generic-go", "generic-python", "dbt"],
          "description": "Execution engine"
        },
        "mode": {
          "type": "string",
          "enum": ["batch", "streaming"],
          "default": "batch",
          "description": "Execution mode"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "anyOf": [
              { "required": ["dataset"] },
              { "required": ["tags"] }
            ],
            "properties": {
              "dataset": {
                "type": "string",
                "description": "Name of the input DataSet"
              },
              "tags": {
                "type": "object",
                "additionalProperties": { "type": "string" },
                "description": "Match datasets by metadata labels"
              },
              "version": {
                "type": "string",
                "description": "Semver range constraint (e.g., >=1.0.0, ^1.2.0)"
              },
              "cell": {
                "type": "string",
                "description": "Cell qualifier for cross-cell resolution"
              },
              "schema": {
                "type": "string",
                "description": "APX module ID for consumer-side schema validation"
              }
            },
            "additionalProperties": false
          },
          "minItems": 1,
          "description": "Input DataSet references (data sources)"
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "anyOf": [
              { "required": ["dataset"] },
              { "required": ["tags"] }
            ],
            "properties": {
              "dataset": {
                "type": "string",
                "description": "Name of the output DataSet"
              },
              "tags": {
                "type": "object",
                "additionalProperties": { "type": "string" },
                "description": "Match datasets by metadata labels"
              },
              "version": {
                "type": "string",
                "description": "Semver range constraint"
              },
              "cell": {
                "type": "string",
                "description": "Cell qualifier for cross-cell resolution"
              },
              "schema": {
                "type": "string",
                "description": "APX module ID for consumer-side schema validation"
              }
            },
            "additionalProperties": false
          },
          "minItems": 1,
          "description": "Output DataSet references (data produced)"
        },
        "image": {
          "type": "string",
          "description": "Container image for generic-go/generic-python/dbt runtimes"
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Container entrypoint override"
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Environment variable name"
              },
              "value": {
                "type": "string",
                "description": "Static value"
              },
              "valueFrom": {
                "type": "object",
                "description": "External value source"
              }
            }
          },
          "description": "Environment variables"
        },
        "trigger": {
          "type": "object",
          "required": ["policy"],
          "properties": {
            "policy": {
              "type": "string",
              "enum": ["schedule", "on-change", "manual", "composite"],
              "description": "Trigger policy"
            },
            "schedule": {
              "type": "object",
              "properties": {
                "cron": {
                  "type": "string",
                  "description": "Cron expression"
                },
                "timezone": {
                  "type": "string",
                  "description": "Timezone for cron"
                }
              },
              "description": "Cron schedule (required when policy is schedule)"
            },
            "policies": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["schedule", "on-change", "manual"]
              },
              "description": "Sub-policies for composite trigger"
            }
          },
          "additionalProperties": false,
          "description": "Trigger configuration for when this transform executes"
        },
        "timeout": {
          "type": "string",
          "pattern": "^\\d+[smh]$",
          "description": "Maximum execution duration (e.g., 30m, 1h)"
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          },
          "description": "CPU/memory requests and limits"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of parallel workers (for streaming mode)"
        },
        "lineage": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether to emit lineage events"
            }
          },
          "description": "Lineage event emission configuration"
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": {
          "runtime": {
            "enum": ["generic-go", "generic-python", "dbt"]
          }
        }
      },
      "then": {
        "required": ["runtime", "inputs", "outputs", "image"]
      }
    }
  },
  "additionalProperties": false
}
