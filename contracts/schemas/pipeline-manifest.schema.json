{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdpp.io/schemas/v1alpha1/pipeline-manifest.schema.json",
  "title": "Pipeline Manifest",
  "description": "Schema for pipeline.yaml - runtime configuration for pipeline execution",
  "type": "object",
  "required": ["apiVersion", "kind", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "cdpp.io/v1alpha1",
      "description": "Schema version"
    },
    "kind": {
      "type": "string",
      "const": "Pipeline",
      "description": "Resource kind"
    },
    "spec": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._/-]*:[a-zA-Z0-9._-]+$|^\\$\\{[A-Z_]+\\}/[a-zA-Z0-9._/-]*:\\$\\{[A-Z_]+\\}$",
          "description": "Container image reference (supports ${REGISTRY} and ${VERSION} placeholders)"
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Override entrypoint"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command arguments"
        },
        "env": {
          "type": "array",
          "items": { "$ref": "#/$defs/envVar" },
          "description": "Environment variables"
        },
        "envFrom": {
          "type": "array",
          "items": { "$ref": "#/$defs/envFromSource" },
          "description": "Environment from ConfigMap/Secret"
        },
        "timeout": {
          "type": "string",
          "pattern": "^([0-9]+(h|m|s))+$",
          "default": "1h",
          "description": "Maximum execution time (e.g., 2h, 30m, 1h30m)"
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 0,
          "description": "Retry count on failure"
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 3,
          "description": "Successful jobs to retain"
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 5,
          "description": "Failed jobs to retain"
        },
        "serviceAccountName": {
          "type": "string",
          "description": "Kubernetes service account to use"
        },
        "nodeSelector": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Node selector for scheduling"
        },
        "tolerations": {
          "type": "array",
          "items": { "$ref": "#/$defs/toleration" },
          "description": "Pod tolerations"
        }
      }
    }
  },
  "$defs": {
    "envVar": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "description": "Environment variable name"
        },
        "value": {
          "type": "string",
          "description": "Static value"
        },
        "valueFrom": {
          "$ref": "#/$defs/envVarSource",
          "description": "Dynamic value source"
        }
      },
      "oneOf": [
        { "required": ["value"] },
        { "required": ["valueFrom"] }
      ]
    },
    "envVarSource": {
      "type": "object",
      "properties": {
        "bindingRef": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]+$",
          "description": "Reference to binding property (e.g., input.events.brokers)"
        },
        "configMapKeyRef": {
          "type": "object",
          "required": ["name", "key"],
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string" }
          }
        },
        "secretKeyRef": {
          "type": "object",
          "required": ["name", "key"],
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string" }
          }
        }
      },
      "oneOf": [
        { "required": ["bindingRef"] },
        { "required": ["configMapKeyRef"] },
        { "required": ["secretKeyRef"] }
      ]
    },
    "envFromSource": {
      "type": "object",
      "properties": {
        "configMapRef": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "optional": { "type": "boolean", "default": false }
          }
        },
        "secretRef": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "optional": { "type": "boolean", "default": false }
          }
        },
        "prefix": {
          "type": "string",
          "description": "Prefix for environment variable names"
        }
      },
      "oneOf": [
        { "required": ["configMapRef"] },
        { "required": ["secretRef"] }
      ]
    },
    "toleration": {
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "operator": { "type": "string", "enum": ["Exists", "Equal"] },
        "value": { "type": "string" },
        "effect": { "type": "string", "enum": ["NoSchedule", "PreferNoSchedule", "NoExecute"] },
        "tolerationSeconds": { "type": "integer" }
      }
    }
  }
}
